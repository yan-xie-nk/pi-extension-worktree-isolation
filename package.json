{
	"name": "pi-extension-worktree-isolation",
	"version": "0.1.0",
	"description": "Pi extension for running parallel subagents in isolated git worktrees.",
	"type": "module",
	"license": "MIT",
	"keywords": ["pi-package", "pi-extension", "pi", "subagent", "git-worktree"],
	"repository": {
		"type": "git",
		"url": "https://github.com/yan-xie-nk/pi-extension-worktree-isolation.git"
	},
	"files": ["README.md", "LICENSE", "index.ts", "subagents.ts", "worktree.ts", "agents/*.md"],
	"scripts": {
		"check": "tsc --noEmit -p tsconfig.json",
		"test": "node --test test/*.test.ts",
		"verify": "npm run check && npm test && npm run pack:dry",
		"pack:dry": "npm pack --dry-run"
	},
	"pi": {
		"extensions": ["./index.ts"]
	},
	"peerDependencies": {
		"@earendil-works/pi-agent-core": "*",
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@earendil-works/pi-agent-core": "0.79.9",
		"@earendil-works/pi-ai": "0.79.9",
		"@earendil-works/pi-coding-agent": "0.79.9",
		"@earendil-works/pi-tui": "0.79.9",
		"@types/node": "22.19.19",
		"typebox": "1.1.38",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
